# Azure Foundry – Projekt-Endpunkt (Format: https://<name>.services.ai.azure.com/api/projects/<project-name>)
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<your-hub>.services.ai.azure.com/api/projects/<your-project>

# Name des Model-Deployments im Foundry-Projekt (z. B. gpt-4o)
AZURE_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
